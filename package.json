{
  "name": "loopi",
  "version": "1.0.0",
  "description": "Local Autonomous Improvement Agent — self-improving bot for a single code repository",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node --loader ts-node/esm agent/index.ts",
    "loopi": "node --loader ts-node/esm agent/index.ts",
    "clean": "rm -rf dist",
    "agent:run": "node --loader ts-node/esm agent/index.ts",
    "agent:status": "node --loader ts-node/esm agent/index.ts status",
    "agent:dashboard": "node --loader ts-node/esm agent/index.ts dashboard",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepare": "pnpm build"
  },
  "dependencies": {
    "diff": "^5.2.0",
    "picocolors": "^1.1.1",
    "simple-git": "^3.25.0",
    "typescript": "^5.6.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/diff": "^5.2.0",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "vitest": "^2.0.0"
  }
}
