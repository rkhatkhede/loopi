{
  "name": "@loopi-cli/loopi",
  "version": "0.0.1",
  "description": "Local Autonomous Improvement Agent — self-improving bot for any code repository",
  "type": "module",
  "bin": {
    "loopi": "dist/cli.js",
    "loopi-cli": "dist/cli.js"
  },
  "files": [
    "dist/",
    "agents/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "picocolors": "^1.1.1",
    "simple-git": "^3.25.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
