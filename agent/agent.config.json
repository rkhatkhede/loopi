{
  "projectName": "loopi",
  "vision": {
    "autoDetectOnMissing": true,
    "askOnInit": true
  },
  "opportunity": {
    "maxSuggestionsPerCycle": 3,
    "historyFile": "agent/opportunity-history.json"
  },
  "humanGate": {
    "enabled": true,
    "timeoutMinutes": 60,
    "autoRejectOnTimeout": true
  },
  "constraints": {
    "maxFilesPerPatch": 3,
    "maxPatchSizeLines": 500,
    "maxPatchSizeBytes": 10240,
    "allowedOperations": [
      "refactor",
      "fix",
      "improve-tests",
      "dedupe",
      "optimize",
      "typing"
    ],
    "forbiddenDirectories": [
      "node_modules",
      "dist",
      "build",
      ".git"
    ]
  },
  "runFrequencyMinutes": 30,
  "git": {
    "commitPrefix": "feat(agent):",
    "branchPrefix": "agent-improvement/",
    "autoPush": false
  }
}
